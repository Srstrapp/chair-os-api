{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "providers": ["node"],
      " phases": {
        "build": {
          "cmds": ["npm install"],
          "priority": 0
        },
        "start": {
          "cmds": ["node src/index.js"],
          "priority": 1
        }
      }
    }
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
